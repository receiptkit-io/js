{
  "name": "receiptkit",
  "version": "0.1.0-beta.4",
  "description": "JavaScript SDK for ReceiptKit — print receipts from any web or Node.js application via HTTP or MQTT",
  "license": "MIT",
  "author": "ReceiptKit",
  "homepage": "https://www.receiptkit.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/receiptkit-io/js.git"
  },
  "keywords": [
    "receiptkit",
    "receipt",
    "printing",
    "pos",
    "thermal",
    "star",
    "mqtt",
    "sdk"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.mjs",
      "require": "./dist/http/index.js"
    },
    "./mqtt": {
      "types": "./dist/mqtt/index.d.ts",
      "import": "./dist/mqtt/index.mjs",
      "require": "./dist/mqtt/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    }
  },
  "dependencies": {
    "mqtt": "^5.14.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
